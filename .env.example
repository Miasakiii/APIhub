# APIHub 环境变量示例
# 复制为 .env 或在 shell / docker-compose 中设置

# --- 服务 ---
APIHUB_PORT=8080
# APIHUB_BIND_ADDR: 自定义监听地址（如 "0.0.0.0" 监听所有网卡）。
# 认证关闭时默认仅监听 127.0.0.1；认证开启时默认监听所有网卡。
# APIHUB_BIND_ADDR=127.0.0.1
APIHUB_DATA_DIR=~/.apihub
# 首次启动会在 APIHUB_DATA_DIR 下生成 .master_key。
# 备份 apihub.db 时必须同时备份 .master_key，否则已加密 API Key 无法恢复。

# --- 认证 ---
# 生产环境必须启用认证！本地开发可设为 false。
APIHUB_AUTH_ENABLED=true
APIHUB_JWT_EXPIRY=168h
# 首次部署后建议关闭注册，防止未授权用户创建账号。
APIHUB_ALLOW_REGISTER=true
# CORS 来源：生产环境必须指定你的实际域名，不要使用 * 或 localhost。
APIHUB_CORS_ORIGIN=http://localhost:5173

# --- 后台同步 ---
APIHUB_SYNC_INTERVAL=5m
APIHUB_SYNCER_INTERVAL=30m
# APIHUB_CC_SWITCH_PATH=C:\Users\you\.cc-switch\cc-switch.db
